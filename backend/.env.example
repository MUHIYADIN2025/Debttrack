# ================================================================
# DebtTrack Backend — Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to version control
# ================================================================

# ── Server ───────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# ── MongoDB ──────────────────────────────────────────────────────
# Local development
MONGODB_URI=mongodb://localhost:27017/debttrack

# MongoDB Atlas (production) — replace with your connection string
# MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/debttrack?retryWrites=true&w=majority

# ── JWT ──────────────────────────────────────────────────────────
JWT_SECRET=replace_this_with_a_long_random_secret_string_min_32_chars
JWT_EXPIRES_IN=30d

# ── Rate Limiting ────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# ── CORS ─────────────────────────────────────────────────────────
# Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# ── PDF Export ───────────────────────────────────────────────────
PDF_COMPANY_NAME=DebtTrack
PDF_LOGO_PATH=./assets/logo.png
